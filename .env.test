# PaperLens - Test Environment Configuration
DEBUG=true
ENVIRONMENT=DEV
APP_VERSION=0.1.0
SERVICE_NAME=paperlens-api-test

# Test Database URL (in-memory or localhost)
POSTGRES_DATABASE_URL=postgresql+asyncpg://test_user:test_password@localhost:5432/test_paperlens_db
POSTGRES_ECHO_SQL=false
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=0

# Test External Services
# OpenSearch Configuration
OPENSEARCH__HOST=http://localhost:9200
OPENSEARCH__INDEX_NAME=paperlens-test-index

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=300

