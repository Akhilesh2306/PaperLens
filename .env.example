# PaperLens - Environment Configuration (Example)
# Copy this file to .env and adjust values as needed

# Application Settings
DEBUG=true
ENVIRONMENT=DEV
APP_VERSION=0.1.0
SERVICE_NAME=paperlens-api

# PostgreSQL Database
POSTGRES_DATABASE_URL=postgresql+asyncpg://test_user:test_password@localhost:5432/paperlens_db
POSTGRES_ECHO_SQL=false
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=0

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=300

# OpenSearch Configuration
OPENSEARCH__HOST=http://localhost:9200
OPENSEARCH__INDEX_NAME=paperlens-papers